<Window x:Class="MarkFlow.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MarkFlow.Views"
    Title="MarkFlow"
    Width="1400" Height="900"
    WindowStartupLocation="CenterScreen"
    Background="#FFFFFF">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderThickness="0,0,0,1" BorderBrush="#1A000000">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="MarkFlow"
                    FontSize="20" FontWeight="Bold" Foreground="#171717" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <Button x:Name="TabMarkdown" Content="마크다운" Click="TabMarkdown_Click"
        Padding="12,6" Margin="0,0,4,0"
        Background="#171717" BorderBrush="#E0E0E0" Foreground="White" BorderThickness="1"/>
                    <Button x:Name="TabMerge" Content="파일 병합" Click="TabMerge_Click"
        Padding="12,6" Margin="0,0,4,0"
        Background="Transparent" Foreground="#615d59" BorderBrush="#E0E0E0" BorderThickness="1"/>
                    <Button x:Name="TabBrainstorm" Content="브레인스토밍" Click="TabBrainstorm_Click"
        Padding="12,6"
        Background="Transparent" Foreground="#615d59" BorderBrush="#E0E0E0" BorderThickness="1"/>
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="TitleText"
                    Text="새 문서" FontSize="15" Foreground="#615d59"
                    VerticalAlignment="Center" Margin="24,0,0,0"/>

                <StackPanel x:Name="EditorButtons" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}" Content="폴더 열기"
                        Click="OpenFolderButton_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="열기"
                        Click="OpenButton_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="저장"
                        Click="SaveButton_Click" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="새 문서"
                        Click="NewDocumentButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 콘텐츠 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="240" MinWidth="100"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="Sidebar" Grid.Column="0" Background="#f6f5f4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="#1A000000">
                        <TextBlock x:Name="FolderNameText" Text="폴더 없음"
                            FontSize="12" FontWeight="SemiBold" Foreground="#615d59"
                            TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <ListBox x:Name="FileListBox" Grid.Row="1"
                        Background="Transparent" BorderThickness="0" Margin="4,8"
                        SelectionChanged="FileListBox_SelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="삭제" Click="DeleteFile_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="14"
                                    Foreground="#F2000000" Padding="12,6"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EBEBEB"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3E2E1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="5"
                HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <Grid Grid.Column="2">
                <local:EditorView x:Name="EditorView" Visibility="Visible"/>
                <local:MergeView x:Name="MergeView" Visibility="Collapsed"/>
                <local:BrainstormView x:Name="BrainstormView" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
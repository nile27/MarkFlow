<Window x:Class="MarkFlow.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
    Title="MarkFlow - 마크다운 에디터"
    Width="1400"
    Height="900"
    WindowStartupLocation="CenterScreen"
    Background="#FFFFFF">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderThickness="0,0,0,1"
            BorderBrush="#1A000000">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="MarkFlow"
                    FontFamily="{StaticResource NotionFont}"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#171717"
                    VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                    Text="{Binding Title}"
                    FontFamily="{StaticResource NotionFont}"
                    FontSize="15"
                    Foreground="#615d59"
                    VerticalAlignment="Center"
                    Margin="40,0,0,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button
                        Style="{StaticResource SecondaryButton}"
                        Content="폴더 열기"
                        Click="OpenFolderButton_Click"
                        Margin="0,0,8,0"/>
                    <Button
                        Style="{StaticResource SecondaryButton}"
                        Content="열기"
                        Click="OpenButton_Click"
                        Margin="0,0,8,0"/>
                    <Button
                        Style="{StaticResource SecondaryButton}"
                        Content="저장"
                        Click="SaveButton_Click"
                        Margin="0,0,8,0"/>
                    <Button
                        Style="{StaticResource PrimaryButton}"
                        Content="새 문서"
                        Click="NewDocumentButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="100"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 사이드바 -->
            <Border Grid.Column="0"
                Background="#f6f5f4"
                BorderThickness="0,0,0,0"
                BorderBrush="#1A000000">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Padding="16,12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#1A000000">
                        <TextBlock
                            x:Name="FolderNameText"
                            Text="폴더 없음"
                            FontFamily="{StaticResource NotionFont}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#615d59"
                            TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <ListBox
                        x:Name="FileListBox"
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="4,8"
                        SelectionChanged="FileListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding Name}"
                                    FontFamily="{StaticResource NotionFont}"
                                    FontSize="14"
                                    Foreground="#F2000000"
                                    Padding="12,6"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EBEBEB"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E3E2E1"/>
                                    </Trigger>
                                </Style.Triggers>
                                <Style.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Style.Resources>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 사이드바 구분선 -->
            <GridSplitter
                Grid.Column="1"
                Width="5"
                HorizontalAlignment="Stretch"
                Background="#E0E0E0"
                Cursor="SizeWE"/>

            <!-- 에디터 -->
            <Border Grid.Column="2"
                Background="#FFFFFF"
                BorderThickness="0,0,0,0"
                BorderBrush="#1A000000">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Background="#FFFFFF"
                        Padding="24,14"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#1A000000">
                        <TextBlock
                            Text="마크다운 편집"
                            FontFamily="{StaticResource NotionFont}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#615d59"
                            Margin="0"/>
                    </Border>

                    <avalonedit:TextEditor
                        Grid.Row="1"
                        x:Name="MarkdownEditor"
                        FontFamily="Consolas, 'Courier New'"
                        FontSize="14"
                        Foreground="#F2000000"
                        LineNumbersForeground="#a39e98"
                        ShowLineNumbers="True"
                        WordWrap="True"
                        Padding="10"/>
                </Grid>
            </Border>

            <!-- 에디터 구분선 -->
            <GridSplitter
                Grid.Column="3"
                Width="5"
                HorizontalAlignment="Stretch"
                Background="#E0E0E0"
                Cursor="SizeWE"/>

            <!-- 미리보기 -->
            <Border Grid.Column="4" Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Background="#FFFFFF"
                        Padding="24,14"
                        BorderThickness="0,0,0,1"
                        BorderBrush="#1A000000">
                        <TextBlock
                            Text="미리보기"
                            FontFamily="{StaticResource NotionFont}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#615d59"
                            Margin="0"/>
                    </Border>

                    <FlowDocumentScrollViewer
                        Grid.Row="1"
                        x:Name="PreviewViewer"
                        IsToolBarVisible="False"
                        VerticalScrollBarVisibility="Auto"
                        Margin="24"
                        Foreground="#F2000000"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
<UserControl x:Class="MarkFlow.Views.EditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <!-- 에디터 -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderThickness="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FFFFFF" Padding="24,14"
                    BorderThickness="0,0,0,1" BorderBrush="#1A000000">
                    <TextBlock Text="마크다운 편집" FontSize="14" FontWeight="SemiBold" Foreground="#615d59"/>
                </Border>
                <avalonedit:TextEditor
                    Grid.Row="1" x:Name="MarkdownEditor"
                    FontFamily="Consolas, 'Courier New'" FontSize="14"
                    ShowLineNumbers="True" WordWrap="True" Padding="10"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

        <!-- 미리보기 -->
        <Border Grid.Column="2" Background="#FFFFFF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#FFFFFF" Padding="24,14"
                    BorderThickness="0,0,0,1" BorderBrush="#1A000000">
                    <TextBlock Text="미리보기" FontSize="14" FontWeight="SemiBold" Foreground="#615d59"/>
                </Border>
                <FlowDocumentScrollViewer
                    Grid.Row="1" x:Name="PreviewViewer"
                    IsToolBarVisible="False" VerticalScrollBarVisibility="Auto" Margin="24"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
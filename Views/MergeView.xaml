<UserControl x:Class="MarkFlow.Views.MergeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- 메인 캔버스 영역 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="클릭 순서대로 파일을 선택하세요"
                    FontSize="13" Foreground="#615d59" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="병합" Click="MergeExecute_Click"
                    Padding="12,6" Margin="0,0,8,0"
                    Background="#171717" Foreground="White" BorderThickness="0"/>
                    <Button Content="초기화" Click="MergeReset_Click"
                    Padding="12,6" Background="Transparent" BorderBrush="#E0E0E0" BorderThickness="1"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
            HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
            PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                <Canvas x:Name="MergeCanvas" Width="2000" Height="1500" Background="#F8F8F8"/>
            </ScrollViewer>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

        <!-- 히스토리 사이드바 -->
        <Border Grid.Column="2" Background="#f6f5f4" BorderThickness="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#f6f5f4" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                    <TextBlock Text="병합 히스토리" FontSize="13" FontWeight="SemiBold"
                    Foreground="#171717" VerticalAlignment="Center" Margin="16,0"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="HistoryPanel" Margin="8"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>